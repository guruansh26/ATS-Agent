# --- Backend ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000

# Postgres
DATABASE_URL=postgresql://ats:ats@localhost:5432/ats?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# API auth (comma separated keys; first key is used by seed script and frontend dev)
API_KEYS=dev-recruiter-key

# LLM provider: "mock" (default, no key required) or "openai"
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_KEY=dev-recruiter-key
